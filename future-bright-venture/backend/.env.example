# ============================================
# DATABASE CONFIGURATION (MySQL)
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=futurebright
DB_USER=root
DB_PASSWORD=your_mysql_password

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3001
NODE_ENV=development
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ============================================
# ADMIN CREDENTIALS
# ============================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ============================================
# STRIPE PAYMENT CONFIGURATION (OPTIONAL)
# ============================================
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# ============================================
# PAYPAL PAYMENT CONFIGURATION (OPTIONAL)
# ============================================
PAYPAL_CLIENT_ID=placeholder
PAYPAL_CLIENT_SECRET=placeholder
PAYPAL_MODE=sandbox

# ============================================
# M-PESA (DARAJA) CONFIGURATION (OPTIONAL)
# ============================================
MPESA_CONSUMER_KEY=placeholder
MPESA_CONSUMER_SECRET=placeholder
MPESA_PASSKEY=placeholder
MPESA_SHORTCODE=174379
MPESA_ENVIRONMENT=sandbox

# ============================================
# FRONTEND URL (for CORS)
# ============================================
FRONTEND_URL=http://localhost:5173
